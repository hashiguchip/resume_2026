{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(npm run:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npx:*)",
      "Bash(mise:*)",
      "Bash(biome:*)",
      "Bash(cog:*)",
      "Bash(hk:*)",
      "Bash(ls:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Skill(check)",
      "Skill(pr)",
      "Skill(pr-review)",
      "Bash(gh:*)"
    ],
    "deny": ["Bash(rm -rf:*)", "Bash(git push --force:*)", "Bash(git reset --hard:*)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true $CLAUDE_FILE_PATHS"
          }
        ]
      }
    ]
  }
}
