# リッスンポート（デフォルト: 8080）
PORT=8080

# Postgres database URL
# Format: postgres://user:pass@host:port/dbname?sslmode=require
# leapcell.io 上では Postgres add-on が DATABASE_URL を自動注入する想定。
# ローカル開発では docker-compose の postgres サービスを指す。
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chokunavi?sslmode=disable

# CORS 許可 Origin（カンマ区切り）
CORS_ORIGINS=http://localhost:3000

# referral code (= ユーザー) は DB の users テーブルで管理する。
# `mise run seed:apply` で SOPS 暗号化された seed YAML の users セクションを投入する。
