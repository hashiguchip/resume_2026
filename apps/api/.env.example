# リッスンポート（デフォルト: 8080）
PORT=8080

# CORS 許可 Origin（カンマ区切り）
CORS_ORIGINS=http://localhost:3000

# 許可コードの SHA-256 ハッシュ（カンマ区切り）
# 生成方法: echo -n "コード文字列" | shasum -a 256
# ⚠ 本番では必ず独自のハッシュに変更すること
AUTH_CODE_HASHES=<your-sha256-hash>

# PricingData JSON 文字列
# シングルクォートで囲むこと（shell の source .env で波括弧が壊れるため）
PRICING_JSON='{"rate":"1円/h","billingHours":"実稼働","trialRate":"1円/h","trialNote":"お試し","patterns":[{"label":"パターンA","trialFlex":0,"trialPeriod":"1ヶ月","regularFlex":0,"regularPeriod":"2ヶ月目〜"}]}'
